                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Get and set token that we got from the body\r",
                  "pm.test(\"Set token as environment variable\", function () {\r",
                  "    let jsonData = pm.response.json();\r",
                  "    pm.environment.set(\"token\", jsonData.token);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Check if there is a Header Content-Type\r",
                  "let hasHeader = false;\r",
                  "pm.request.headers.each(function(header) {\r",
                  "    if (header.key.toLowerCase() === \"content-type\") {\r",
                  "        hasHeader = true;\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "// If no - add it\r",
                  "if (!hasHeader) {\r",
                  "    pm.request.headers.add({\r",
                  "        key: \"Content-Type\",\r",
                  "        value: \"application/json\"\r",
                  "    });\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
