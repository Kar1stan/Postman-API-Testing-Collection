                  "pm.test(\"Verify that status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Verify that booking was created\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "\r",
                  "    // Checking of the upper level\r",
                  "    pm.expect(jsonData).to.have.property(\"bookingid\");\r",
                  "    pm.expect(jsonData).to.have.property(\"booking\");\r",
